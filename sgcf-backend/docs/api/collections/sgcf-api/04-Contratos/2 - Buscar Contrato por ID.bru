get {
  url: {{baseUrl}}/api/v1/contratos/{{contratoId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Accept: application/json
}

docs {
  Retorna detalhes completos de um contrato.
  Política: Leitura
}
