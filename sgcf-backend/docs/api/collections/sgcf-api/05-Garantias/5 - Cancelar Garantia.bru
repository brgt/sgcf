meta {
  name: Cancelar Garantia
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/api/v1/contratos/{{contratoId}}/garantias/{{garantiaId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Accept: application/json
}

docs {
  Cancela (desativa) uma garantia do contrato.
  Política: Gerencial
}
