meta {
  name: Indicadores de Garantias
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/v1/contratos/{{contratoId}}/garantias/indicadores
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Accept: application/json
}

docs {
  Retorna índices e cobertura agregada das garantias do contrato.
  Política: Leitura
}
