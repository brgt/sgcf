meta {
  name: Listar Bancos
  type: http
  seq: 1
}

get {
  url: http://127.0.0.1:5000/api/v1/bancos?search=
  body: none
  auth: bearer
}

params:query {
  search: 
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.status === 200 && res.body && res.body.length > 0) {
    bru.setEnvVar("bancoId", res.body[0].id);
  }
}

docs {
  Lista todos os bancos. Salva o ID do primeiro como `bancoId` no environment.
  Política: Leitura
}
