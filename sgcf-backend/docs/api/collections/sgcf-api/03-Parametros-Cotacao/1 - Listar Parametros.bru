meta {
  name: Listar Parametros
  type: http
  seq: 1
}

get {
  url: http://127.0.0.1:5000/api/v1/parametros-cotacao
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.status === 200 && res.body && res.body.length > 0) {
    bru.setEnvVar("parametroCotacaoId", res.body[0].id);
  }
}

docs {
  Lista tipos de cotação cadastrados.
  Política: Leitura
}
